N8N_WEBHOOK_URL=https://n8n.utopiaflow.tech/webhook/franco-chat

# Transcripción de audio (Whisper de OpenAI). El frontend transcribe todo el
# audio server-side antes de mandar al webhook, así n8n solo recibe texto.
OPENAI_API_KEY=sk-...
# Opcional: modelo de transcripción. Por defecto whisper-1.
# OPENAI_TRANSCRIBE_MODEL=whisper-1
