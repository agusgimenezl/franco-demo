N8N_WEBHOOK_URL=https://n8n.utopiaflow.tech/webhook/franco-chat

# Token que viaja como header X-Franco-Auth en todas las llamadas a n8n (debe
# coincidir con la credencial Header Auth configurada ahí). Nunca el valor real acá.
N8N_AUTH_TOKEN=

# PIN que valida el server antes de borrar un lead/sesión en /api/session-delete.
# Nunca el valor real acá.
CRM_PIN=

# Transcripción de audio (Whisper de OpenAI). El frontend transcribe todo el
# audio server-side antes de mandar al webhook, así n8n solo recibe texto.
OPENAI_API_KEY=sk-...
# Opcional: modelo de transcripción. Por defecto whisper-1.
# OPENAI_TRANSCRIBE_MODEL=whisper-1
